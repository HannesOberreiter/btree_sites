---
// btree.tv — Example videos for the btree beekeeping app
// Replace the placeholder content with real videos and copy
const videos = [
  // {
  //   title: 'Getting started with btree',
  //   description: 'A quick overview of the btree beekeeping app.',
  //   youtubeId: 'YOUR_VIDEO_ID',
  // },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>btree.tv — Watch btree in action</title>
    <meta
      name="description"
      content="Video tutorials and demos for btree — the modern beekeeping management app."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --color-bg: #fffdf7;
        --color-text: #1a1a1a;
        --color-accent: #f5a623;
        --color-muted: #6b6b6b;
        --color-border: #e8e0cc;
        font-family: system-ui, -apple-system, sans-serif;
      }

      body {
        background: var(--color-bg);
        color: var(--color-text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      header {
        border-bottom: 1px solid var(--color-border);
        padding: 1.25rem 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      header a {
        text-decoration: none;
        color: inherit;
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: -0.02em;
      }

      header span { color: var(--color-accent); }

      main {
        flex: 1;
        max-width: 1100px;
        margin: 0 auto;
        padding: 3rem 2rem;
        width: 100%;
      }

      .hero {
        text-align: center;
        margin-bottom: 4rem;
      }

      .hero h1 {
        font-size: clamp(1.8rem, 4vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 1rem;
      }

      .hero p {
        color: var(--color-muted);
        font-size: 1.1rem;
        max-width: 560px;
        margin: 0 auto 2rem;
        line-height: 1.6;
      }

      .hero a.cta {
        display: inline-block;
        background: var(--color-accent);
        color: #fff;
        padding: 0.75rem 1.75rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 1rem;
        transition: opacity 0.15s;
      }

      .hero a.cta:hover { opacity: 0.85; }

      .video-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2rem;
      }

      .video-card {
        border: 1px solid var(--color-border);
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
      }

      .video-card iframe {
        width: 100%;
        aspect-ratio: 16/9;
        border: none;
        display: block;
      }

      .video-card-body { padding: 1rem 1.25rem 1.25rem; }

      .video-card-body h2 {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 0.4rem;
      }

      .video-card-body p {
        font-size: 0.875rem;
        color: var(--color-muted);
        line-height: 1.5;
      }

      .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--color-muted);
        border: 2px dashed var(--color-border);
        border-radius: 12px;
      }

      .empty-state p { margin-top: 0.5rem; font-size: 0.95rem; }

      footer {
        border-top: 1px solid var(--color-border);
        padding: 1.5rem 2rem;
        text-align: center;
        font-size: 0.875rem;
        color: var(--color-muted);
      }

      footer a { color: var(--color-accent); text-decoration: none; }
    </style>
  </head>
  <body>
    <header>
      <a href="/">btree<span>.tv</span></a>
    </header>

    <main>
      <section class="hero">
        <h1>See btree in action 🐝</h1>
        <p>
          Video tutorials and demos for <strong>btree</strong> — the modern
          beekeeping management app.
        </p>
        <a class="cta" href="https://www.btree.at">Try btree for free →</a>
      </section>

      {videos.length > 0 ? (
        <div class="video-grid">
          {videos.map((v) => (
            <div class="video-card">
              <iframe
                src={`https://www.youtube-nocookie.com/embed/${v.youtubeId}`}
                title={v.title}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
              <div class="video-card-body">
                <h2>{v.title}</h2>
                {v.description && <p>{v.description}</p>}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <strong>Videos coming soon!</strong>
          <p>Check back to see tutorials and demos for the btree app.</p>
        </div>
      )}
    </main>

    <footer>
      <p>
        © {new Date().getFullYear()} btree —
        <a href="https://www.btree.at">btree.at</a> ·
        <a href="https://www.btree.at/imprint">Imprint</a> ·
        <a href="https://www.btree.at/data-privacy">Privacy</a>
      </p>
    </footer>
  </body>
</html>
