---
import Layout from '../../layouts/Layout.astro';
import { videosForLang, BUNNY_LIBRARY_ID } from '../../config';

const lang = 'de' as const;
const videos = videosForLang(lang);
---

<Layout
  lang={lang}
  title="b.tree TV – Tutorial-Videos"
  description="Schau dir Tutorial-Videos für die b.tree Imkerei-App an. Lerne NFC, QR-Codes, PWA-Installation und mehr."
  canonicalUrl="https://www.btree.tv/de/"
>
  <section class="hero">
    <h1>b.tree Tutorials</h1>
    <p>Kurze Video-Anleitungen, die dir helfen, das Beste aus der b.tree Imkerei-App herauszuholen.</p>
  </section>

  <main>
    <div class="inner">
      <div class="intro">
        <p>
          Willkommen bei <strong>b.tree TV</strong> — deinem Video-Hilfebereich für die
          <a href="https://www.btree.at/de" target="_blank" rel="noopener">b.tree Imkerei-App</a>.
          Diese Tutorials führen dich durch die wichtigsten Funktionen, damit du deine Völker,
          Standorte und Aufzeichnungen sicher verwalten kannst. Neu bei b.tree?
          <a href="https://www.btree.at/de" target="_blank" rel="noopener">Jetzt starten auf btree.at ↗</a>
        </p>
      </div>
      <div class="video-grid">
        {videos.map((video) => (
          <article class="video-card">
            <div class="video-wrapper">
              <iframe
                src={`https://player.mediadelivery.net/embed/${BUNNY_LIBRARY_ID}/${video.id}?autoplay=false&loop=false&muted=false&preload=false&responsive=true`}
                loading="lazy"
                allow="accelerometer;gyroscope;autoplay;encrypted-media;picture-in-picture;"
                allowfullscreen
                title={video.titleDe}
              ></iframe>
            </div>
            <div class="video-info">
              <h2>{video.titleDe}</h2>
              <p>{video.descDe}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>
</Layout>
