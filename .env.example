# Bunny CDN credentials — used by scripts/bunny.sh for local operations
# Copy this file to .env and fill in your values.
# These values are also set as GitHub Actions secrets/variables for CI/CD.

# Shared Bunny API key (account-level, used for cache purge)
BUNNY_API_KEY=

# btree_info (btree.at)
BTREE_INFO_STORAGE_ZONE_NAME=
BTREE_INFO_STORAGE_PASSWORD=
BTREE_INFO_PULL_ZONE_ID=

# wizbee_info (wiz-bee.com)
WIZBEE_INFO_STORAGE_ZONE_NAME=
WIZBEE_INFO_STORAGE_PASSWORD=
WIZBEE_INFO_PULL_ZONE_ID=

# btree_tv (btree.tv)
BTREE_TV_STORAGE_ZONE_NAME=
BTREE_TV_STORAGE_PASSWORD=
BTREE_TV_PULL_ZONE_ID=
